generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ModuleKey {
  LOGGING
  PERMISSIONS
  MODERATION
  TICKETS
  APPLICATIONS
  APPEALS
  SCHEDULED_MESSAGES
  WELCOME
  REACTION_ROLES
  GIVEAWAYS
  BIRTHDAYS
  LEVELING
  SERVER_STATS
  JOIN_TO_CREATE
  CUSTOM_COMMANDS
  UTILITY
}

enum LogDeliveryMode {
  IMMEDIATE
  BATCHED
  DISABLED
}

enum AuditSeverity {
  INFO
  WARNING
  DANGEROUS
  ERROR
}

model GuildConfig {
  id             String   @id @default(cuid())
  guildId        String   @unique
  guildName      String?
  timezone       String   @default("America/New_York")
  defaultLogChannelId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  modules        ModuleConfig[]
  teams          PermissionTeam[]
  logSettings    LogSetting[]
  auditLogs      AuditLog[]
  logQueue       LogQueueItem[]
}

model ModuleConfig {
  id        String    @id @default(cuid())
  guildId   String
  moduleKey ModuleKey
  enabled   Boolean   @default(false)
  logChannelId String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  guild     GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@unique([guildId, moduleKey])
  @@index([guildId])
}

model PermissionTeam {
  id          String   @id @default(cuid())
  guildId     String
  name        String
  description String?
  isSystemTeam Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guild       GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  roles       PermissionTeamRole[]
  users       PermissionTeamUser[]
  permissions CommandPermission[]

  @@unique([guildId, name])
  @@index([guildId])
}

model PermissionTeamRole {
  id        String @id @default(cuid())
  teamId    String
  roleId    String
  createdAt DateTime @default(now())

  team      PermissionTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, roleId])
}

model PermissionTeamUser {
  id        String @id @default(cuid())
  teamId    String
  userId    String
  createdAt DateTime @default(now())

  team      PermissionTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model CommandPermission {
  id          String @id @default(cuid())
  guildId     String
  teamId      String
  actionKey   String
  allow       Boolean @default(true)
  channelScope String @default("*")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team        PermissionTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, actionKey, channelScope])
  @@index([guildId, actionKey])
}

model LogSetting {
  id           String @id @default(cuid())
  guildId      String
  eventKey     String
  deliveryMode LogDeliveryMode @default(BATCHED)
  channelId    String?
  batchIntervalSeconds Int @default(300)
  maxBatchItems Int @default(25)
  enabled       Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  guild         GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@unique([guildId, eventKey])
  @@index([guildId])
}

model LogQueueItem {
  id        String @id @default(cuid())
  guildId   String
  eventKey  String
  title     String
  body      String
  metadata  Json?
  createdAt DateTime @default(now())
  flushedAt DateTime?

  guild     GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@index([guildId, eventKey, flushedAt])
}

model AuditLog {
  id          String @id @default(cuid())
  guildId     String
  actorUserId String?
  actionKey   String
  targetType  String?
  targetId    String?
  severity    AuditSeverity @default(INFO)
  summary     String
  metadata    Json?
  createdAt   DateTime @default(now())

  guild       GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@index([guildId, actionKey])
  @@index([guildId, createdAt])
}
