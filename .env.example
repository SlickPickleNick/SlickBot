# SlickBot Discord credentials
# Required: create these in Discord Developer Portal -> Applications -> your bot.
DISCORD_TOKEN="replace_with_bot_token"
DISCORD_CLIENT_ID="replace_with_application_client_id"

# Optional but recommended while testing.
# This registers slash commands to one server quickly instead of globally.
DISCORD_GUILD_ID="replace_with_your_server_id"

# Railway PostgreSQL variable.
# In Railway, add a PostgreSQL service and reference its DATABASE_URL variable here.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Startup behavior
AUTO_DEPLOY_COMMANDS="true"
BOT_OWNER_IDS="replace_with_your_discord_user_id"
DEFAULT_TIMEZONE="America/New_York"
LOG_BATCH_FLUSH_SECONDS="300"
NODE_ENV="production"

# Railway health endpoint. Railway injects PORT automatically, but this fallback is safe.
WEB_HOST="0.0.0.0"
PORT="3000"

# Compatibility aliases also supported by SlickBot:
# CLIENT_ID can be used instead of DISCORD_CLIENT_ID.
# GUILD_ID can be used instead of DISCORD_GUILD_ID.
# OWNER_IDS can be used instead of BOT_OWNER_IDS.
# POSTGRES_URL can be used instead of DATABASE_URL for app runtime, but Railway/Prisma should use DATABASE_URL.
