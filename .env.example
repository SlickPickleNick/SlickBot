# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_client_id_here
DISCORD_GUILD_ID=your_test_server_guild_id_here

# TitanBot-style aliases are also supported:
# CLIENT_ID=your_discord_application_client_id_here
# GUILD_ID=your_test_server_guild_id_here
# OWNER_IDS=your_discord_user_id

# Railway PostgreSQL normally provides DATABASE_URL automatically.
DATABASE_URL=postgresql://postgres:password@host:5432/railway
# TitanBot-style alias also supported:
# POSTGRES_URL=postgresql://postgres:password@host:5432/railway

AUTO_DEPLOY_COMMANDS=true
BOT_OWNER_IDS=your_discord_user_id
DEFAULT_TIMEZONE=America/New_York
LOG_BATCH_FLUSH_SECONDS=300
NODE_ENV=production
WEB_HOST=0.0.0.0
PORT=3000

# Bot Status / Activity Defaults
# Supported statuses: online, idle, dnd, invisible
# Supported activity types: PLAYING, WATCHING, LISTENING, COMPETING, STREAMING, NONE
DEFAULT_BOT_STATUS=online
DEFAULT_BOT_ACTIVITY_TYPE=STREAMING
DEFAULT_BOT_ACTIVITY_TEXT=Go follow Nick!
# DEFAULT_BOT_ACTIVITY_URL=https://twitch.tv/slickpicklenick
