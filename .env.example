# Discord application credentials
DISCORD_TOKEN="replace_with_bot_token"
DISCORD_CLIENT_ID="replace_with_application_client_id"

# Optional but recommended for fast command updates while testing on your server.
# If omitted, slash commands deploy globally and can take longer to appear.
DISCORD_GUILD_ID="replace_with_your_server_id"

# Railway Postgres variable. In Railway, set this to the Postgres DATABASE_URL reference.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Whether the bot should register slash commands on startup.
AUTO_DEPLOY_COMMANDS="true"

# Comma-separated Discord user IDs who can bypass all bot permission checks.
BOT_OWNER_IDS="replace_with_your_discord_user_id"

# Bot behavior
DEFAULT_TIMEZONE="America/New_York"
LOG_BATCH_FLUSH_SECONDS="300"
NODE_ENV="development"
