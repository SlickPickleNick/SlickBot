{
  "name": "slickbot",
  "version": "0.3.6",
  "private": true,
  "description": "SlickBot all-in-one Discord server management bot with seeded default permission levels for commands/modules, public actions, and support workflow permissions.",
  "main": "src/index.js",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "deploy:commands": "node src/deployCommands.js",
    "db:init": "node src/services/initDatabase.js",
    "validate:commands": "node src/scripts/validateCommands.js"
  },
  "dependencies": {
    "discord.js": "^14.22.1",
    "dotenv": "^16.4.7",
    "pg": "^8.13.3"
  },
  "packageManager": "npm@10.9.2"
}
